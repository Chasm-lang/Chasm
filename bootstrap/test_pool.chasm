defstruct Node do
  tag  :: atom
  a    :: int
  b    :: int
  name :: string
end

defp pool_set(pool :: []Node, idx :: int, node :: Node) do
  pool.set(idx, node)
end

defp pool_alloc(pool :: []Node, np :: int, node :: Node) :: int do
  pool.set(np, node)
  return np + 1
end

def main() do
  pool :: []Node = []
  empty :: Node = Node{ tag: :none, a: 0, b: 0, name: "" }
  i = 0
  while i < 100 do
    pool.push(empty)
    i = i + 1
  end

  np = 0
  np = pool_alloc(pool, np, Node{ tag: :ident, a: 0, b: 0, name: "foo" })
  np = pool_alloc(pool, np, Node{ tag: :int_lit, a: 42, b: 0, name: "42" })
  np = pool_alloc(pool, np, Node{ tag: :call, a: 0, b: 1, name: "bar" })

  print(np)
  n0 = pool.get(0)
  n1 = pool.get(1)
  n2 = pool.get(2)
  print(n0.tag)
  print(n0.name)
  print(n1.tag)
  print(n1.a)
  print(n2.tag)
  print(n2.name)
end
