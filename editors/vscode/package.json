{
  "name": "chasm-language",
  "displayName": "Chasm",
  "description": "Language support for Chasm — syntax highlighting, diagnostics, hover, completions, formatting, and CodeLens via chasm-lsp",
  "version": "0.4.0",
  "publisher": "chasm",
  "icon": "Icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "chasm",
        "aliases": [
          "Chasm",
          "chasm"
        ],
        "extensions": [
          ".chasm"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "chasm",
        "scopeName": "source.chasm",
        "path": "./syntaxes/chasm.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "chasm",
        "path": "./snippets/chasm.json"
      }
    ],
    "commands": [
      {
        "command": "chasm.runFile",
        "title": "Chasm: Run File",
        "icon": "$(play)"
      },
      {
        "command": "chasm.formatFile",
        "title": "Chasm: Format File"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "chasm.runFile",
          "when": "resourceLangId == chasm",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Chasm",
      "properties": {
        "chasm.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to chasm-lsp binary. Leave empty to use the one on your PATH."
        },
        "chasm.chasmPath": {
          "type": "string",
          "default": "chasm",
          "description": "Path to the chasm CLI binary used for running files."
        },
        "[chasm]": {
          "type": "object",
          "default": {
            "editor.formatOnSave": true,
            "editor.defaultFormatter": "chasm.chasm-language"
          },
          "description": "Default editor settings for Chasm files."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run bundle -- --watch",
    "package": "vsce package --allow-missing-repository",
    "vscode:prepublish": "npm run bundle"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0"
  }
}
